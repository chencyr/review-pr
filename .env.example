# 只需設定其中一個 provider，系統會自動偵測。
# 若同時設定多個，優先順序: GitHub > Bitbucket

# === Provider: GitHub ===
GITHUB_TOKEN=your_github_token
GITHUB_OWNER=your_org_or_username
GITHUB_REPO=your_repo

# === Provider: Bitbucket Cloud ===
# 建立方式: Bitbucket > Repository/Workspace Settings > Access Tokens
# 所需權限: Repositories (Read), Pull Requests (Read/Write)
BITBUCKET_TOKEN=your_access_token_here
BITBUCKET_WORKSPACE=your_workspace
BITBUCKET_REPO=your_repo
